APP_NAME="Kalapak Code Team"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Optional comma-separated extra origins for CORS only (e.g. keep *.onrender.com while FRONTEND_URL is your custom domain).
# CORS_ALLOWED_ORIGINS=https://your-service.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=kalapak_db
DB_USERNAME=kalapak_user
DB_PASSWORD=kalapak_secret
# Local/default: prefer (works with non-SSL postgres). Set to require for managed DBs that enforce TLS.
DB_SSLMODE=prefer

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000

MAIL_MAILER=resend
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM_ADDRESS=noreply@kalapak-team.space
MAIL_FROM_NAME="Kalapak Code Team"

# Supabase Storage (S3-compatible)
SUPABASE_ENDPOINT=https://YOUR_PROJECT_ID.supabase.co/storage/v1/s3
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ACCESS_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_BUCKET=kalapak-assets
SUPABASE_REGION=us-east-1

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY= 0x4AAAAAAC4BOcvt_5BMWUI3JaB4D7dEArs

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://kalapakspace-backend.onrender.com/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://kalapakspace-backend.onrender.com/auth/github/callback
